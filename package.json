{
  "name": "curator",
  "version": "0.1.0",
  "description": "Privacy-first, agent-first local data curation store with an MCP interface. Agents collaborate on curated data; metadata (source, timestamps, authorship, comments, history) is managed automatically.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "curator": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "files": [
    "src",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "bun run src/index.ts start --foreground",
    "start": "bun run src/index.ts start",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun build ./src/index.ts --compile --outfile dist/curator"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "data-curation",
    "agents",
    "sqlite",
    "privacy-first",
    "local-first"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2"
  }
}
